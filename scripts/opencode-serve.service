[Unit]
Description=OpenCode AI Serve - AI coding assistant backend
After=network.target
Before=opencode-qq-bot.service

[Service]
Type=simple
User=linx
Environment="PATH=/home/linx/.bun/bin:/home/linx/.opencode/bin:/usr/local/bin:/usr/bin:/bin"
ExecStart=/home/linx/.opencode/bin/opencode serve --hostname 127.0.0.1 --port 4096
Restart=always
RestartSec=5
StandardOutput=append:/mnt/fireshare/code/opencode-qq-bot/logs/opencode-serve.log
StandardError=append:/mnt/fireshare/code/opencode-qq-bot/logs/opencode-serve-error.log

[Install]
WantedBy=multi-user.target
